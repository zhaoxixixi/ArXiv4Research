# Chat completion provider (OpenAI-compatible, e.g. DeepSeek)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Embedding provider (default: Alibaba DashScope compatible endpoint)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional rerank provider (falls back to DashScope if omitted in runtime logic)
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks

# Optional compatibility alias used by some deployments
DASHSCOPE_API_KEY=
